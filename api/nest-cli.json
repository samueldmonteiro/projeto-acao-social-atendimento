{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "deleteOutDir": true,
    "assets": [
      {
        "include": "generated/prisma/**/*.+(node|so|dll|dylib)",
        "outDir": "dist"
      }
    ]
  }
}
